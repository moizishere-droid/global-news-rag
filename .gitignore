'''
# Create .gitignore file
@"
# Python
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
venv/
env/
ENV/

# Environment variables
.env

# Data files (too large for git)
data/raw/*
data/processed/*
data/vectorstore/*
data/graphstore/*
!data/raw/.gitkeep
!data/processed/.gitkeep
!data/vectorstore/.gitkeep
!data/graphstore/.gitkeep

# Jupyter Notebook
.ipynb_checkpoints
*.ipynb_checkpoints/

# IDEs
.vscode/
.idea/
*.swp
*.swo

# OS
.DS_Store
Thumbs.db

# Models and large files
*.pkl
*.h5
*.onnx
*.pt
*.pth

# Logs
*.log
logs/

# Distribution
dist/
build/
*.egg-info/

# Testing
.pytest_cache/
.coverage
htmlcov/

# Docker
*.pid
*.seed
*.pid.lock
"@ | Out-File -FilePath .gitignore -Encoding utf8
'''